{
  "name": "android-helper",
  "displayName": "Android Helper",
  "description": "Android Dev Companion for Cursor/VS Code - Device management and app lifecycle controls",
  "version": "0.0.12",
  "publisher": "liumeng1201",
  "repository": {
    "type": "git",
    "url": "https://github.com/liumeng1201/android-helper"
  },
  "icon": "assets/android-studio-macos-transparent.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Debuggers",
    "Testing",
    "Other"
  ],
  "keywords": [
    "android",
    "android studio",
    "avd",
    "emulator",
    "logcat",
    "gradle",
    "kotlin",
    "mobile",
    "device",
    "run",
    "debug",
    "build variant",
    "adb"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:android-helper-avd-dropdown",
    "onView:android-helper-avd",
    "onView:android-helper-build-variant",
    "onLanguage:kotlin",
    "onCommand:android-helper.avdlist-refresh",
    "onCommand:android-helper.setup-wizard",
    "onCommand:android-helper.setup-sdkpath",
    "onCommand:android-helper.setup-avdmanager",
    "onCommand:android-helper.setup-emulator"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "android-helper",
          "title": "Android Helper",
          "icon": "assets/android-studio.svg"
        }
      ]
    },
    "views": {
      "android-helper": [
        {
          "id": "android-helper-avd-dropdown",
          "name": "Android Helper",
          "type": "webview",
          "when": "true"
        },
        {
          "id": "android-helper-avd",
          "name": "Android Virtual Device",
          "contextualTitle": "AVD Manager - Android Virtual Device",
          "when": "true"
        },
        {
          "id": "android-helper-build-variant",
          "name": "Build Variant",
          "contextualTitle": "Build Variant",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "android-helper.selectBuildVariant",
        "title": "Select Build Variant",
        "icon": "$(tools)"
      },
      {
        "command": "android-helper.runApp",
        "title": "Run App",
        "icon": "$(play)"
      },
      {
        "command": "android-helper.stopApp",
        "title": "Stop App",
        "icon": "$(debug-stop)"
      },
      {
        "command": "android-helper.clearData",
        "title": "Clear Data",
        "icon": "$(trash)"
      },
      {
        "command": "android-helper.uninstallApp",
        "title": "Uninstall",
        "icon": "$(trashcan)"
      },
      {
        "command": "android-helper.startLogcat",
        "title": "Start Logcat",
        "icon": "$(play)"
      },
      {
        "command": "android-helper.stopLogcat",
        "title": "Stop Logcat",
        "icon": "$(stop)"
      },
      {
        "command": "android-helper.pauseLogcat",
        "title": "Pause Logcat",
        "icon": "$(debug-pause)"
      },
      {
        "command": "android-helper.resumeLogcat",
        "title": "Resume Logcat",
        "icon": "$(debug-continue)"
      },
      {
        "command": "android-helper.clearLogcat",
        "title": "Clear Logcat",
        "icon": "$(clear-all)"
      },
      {
        "command": "android-helper.setLogLevel",
        "title": "Set Log Level",
        "icon": "$(filter)"
      },
      {
        "command": "android-helper.startEmulator",
        "title": "Start Emulator",
        "icon": "$(device-mobile)"
      },
      {
        "command": "android-helper.selectEmulator",
        "title": "Select Emulator",
        "icon": "$(device-mobile)"
      },
      {
        "command": "android-helper.bootEmulator",
        "title": "Boot Emulator",
        "icon": "$(play)"
      },
      {
        "command": "android-helper.avdlist-refresh",
        "title": "Refresh AVD List",
        "shortTitle": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "android-helper.avd-create",
        "title": "Create",
        "icon": "$(plus)"
      },
      {
        "command": "android-helper.avd-launch",
        "title": "Launch",
        "icon": "$(run)"
      },
      {
        "command": "android-helper.avd-edit",
        "title": "Edit",
        "icon": "$(notebook-edit)"
      },
      {
        "command": "android-helper.avd-showdir",
        "title": "Open AVD folder",
        "icon": "$(folder)"
      },
      {
        "command": "android-helper.avd-showconfigfile",
        "title": "Open AVD config.ini",
        "icon": "$(preferences-open-settings)"
      },
      {
        "command": "android-helper.avd-delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "android-helper.setup-wizard",
        "title": "Run Setup Wizard",
        "category": "Android Helper",
        "icon": "$(wrench)"
      },
      {
        "command": "android-helper.setup-sdkpath",
        "title": "Update SDK Root Path",
        "category": "Android Helper"
      },
      {
        "command": "android-helper.setup-avdmanager",
        "title": "Update AVD Manager Path",
        "category": "Android Helper"
      },
      {
        "command": "android-helper.setup-emulator",
        "title": "Update Emulator Path",
        "category": "Android Helper"
      },
      {
        "command": "android-helper.avd-select",
        "title": "Select Emulator",
        "icon": "$(check)"
      },
      {
        "command": "android-helper.buildvariant-select",
        "title": "Select Build Variant",
        "icon": "$(check)"
      },
      {
        "command": "android-helper.buildvariant-refresh",
        "title": "Refresh Build Variants",
        "icon": "$(refresh)"
      },
      {
        "command": "android-helper.openAndroidProject",
        "title": "Open an Android project",
        "category": "Android Helper",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "android-helper.avdlist-refresh",
          "when": "view == android-helper-avd",
          "group": "navigation@2"
        },
        {
          "command": "android-helper.buildvariant-refresh",
          "when": "view == android-helper-build-variant",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "android-helper.avd-launch",
          "when": "view == android-helper-avd && viewItem == avd",
          "group": "inline@1"
        },
        {
          "command": "android-helper.avd-edit",
          "when": "view == android-helper-avd && viewItem == avd",
          "group": "inline@2"
        },
        {
          "command": "android-helper.avd-showconfigfile",
          "when": "view == android-helper-avd",
          "group": "inline@3"
        },
        {
          "command": "android-helper.avd-showdir",
          "when": "view == android-helper-avd",
          "group": "inline@4"
        },
        {
          "command": "android-helper.avd-delete",
          "when": "view == android-helper-avd && viewItem == avd",
          "group": "avd-menu@3"
        }
      ],
      "commandPalette": [
        {
          "command": "android-helper.selectBuildVariant",
          "when": "true"
        },
        {
          "command": "android-helper.runApp",
          "when": "true"
        },
        {
          "command": "android-helper.stopApp",
          "when": "true"
        },
        {
          "command": "android-helper.clearData",
          "when": "true"
        },
        {
          "command": "android-helper.uninstallApp",
          "when": "true"
        },
        {
          "command": "android-helper.startLogcat",
          "when": "true"
        },
        {
          "command": "android-helper.stopLogcat",
          "when": "true"
        },
        {
          "command": "android-helper.pauseLogcat",
          "when": "true"
        },
        {
          "command": "android-helper.resumeLogcat",
          "when": "true"
        },
        {
          "command": "android-helper.clearLogcat",
          "when": "true"
        },
        {
          "command": "android-helper.setLogLevel",
          "when": "true"
        },
        {
          "command": "android-helper.startEmulator",
          "when": "true"
        },
        {
          "command": "android-helper.avdlist-refresh",
          "when": "true"
        },
        {
          "command": "android-helper.avd-create",
          "when": "true"
        },
        {
          "command": "android-helper.avd-launch",
          "when": "true"
        },
        {
          "command": "android-helper.avd-edit",
          "when": "true"
        },
        {
          "command": "android-helper.avd-showdir",
          "when": "true"
        },
        {
          "command": "android-helper.avd-showconfigfile",
          "when": "true"
        },
        {
          "command": "android-helper.avd-delete",
          "when": "true"
        },
        {
          "command": "android-helper.setup-sdkpath",
          "when": "true"
        },
        {
          "command": "android-helper.setup-avdmanager",
          "when": "true"
        },
        {
          "command": "android-helper.setup-emulator",
          "when": "true"
        },
        {
          "command": "android-helper.avd-select",
          "when": "true"
        },
        {
          "command": "android-helper.buildvariant-select",
          "when": "true"
        },
        {
          "command": "android-helper.buildvariant-refresh",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Android Helper",
      "properties": {
        "android-helper.adbPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to ADB executable. Leave empty to auto-detect."
        },
        "android-helper.autoSelectDevice": {
          "type": "boolean",
          "default": false,
          "description": "Automatically select the first online device when available."
        },
        "android-helper.devicePollInterval": {
          "type": "number",
          "default": 3000,
          "description": "Device refresh interval in milliseconds (default: 3000ms)."
        },
        "android-helper.logcatBufferSize": {
          "type": "number",
          "default": 10000,
          "description": "Maximum number of log lines to buffer in memory (default: 10000)."
        },
        "android-helper.emulatorPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to emulator executable. Leave empty to auto-detect."
        },
        "android-helper.sdkPath": {
          "title": "Android SDK Root Path",
          "type": "string",
          "default": "",
          "markdownDescription": "The location of the Android SDK Root Path. If blank, it will attempt to find it from the `ANDROID_SDK_ROOT` or `ANDROID_HOME` environment variable."
        },
        "android-helper.avdHome": {
          "title": "Android AVD Home Path",
          "type": "string",
          "default": "",
          "markdownDescription": "The location of the Android AVD Home Path. If blank, it will attempt to find it from the `ANDROID_AVD_HOME` environment variable or SDK Default."
        },
        "android-helper.cmdVersion": {
          "title": "Android Command-Line Tools Version",
          "type": "string",
          "default": "latest",
          "description": "Android SDK Command-Line Tools Version"
        },
        "android-helper.executable": {
          "title": "AVD Manager executable (optional)",
          "type": "string",
          "default": "avdmanager",
          "description": "AVD Manager executable path"
        },
        "android-helper.sdkManager": {
          "title": "Android SDK Manager executable (optional)",
          "type": "string",
          "default": "sdkmanager",
          "description": "Android SDK Manager executable path"
        },
        "android-helper.emulatorOpt": {
          "title": "Android emulator options (optional)",
          "type": "string",
          "default": "",
          "markdownDescription": "Android emulator options. [Start the emulator from the command line](https://developer.android.com/studio/run/emulator-commandline)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run compile:webviews",
    "compile:extension": "tsc -p ./ && npm run copy:scripts",
    "copy:scripts": "node scripts/copy-scripts.js",
    "compile:webviews": "webpack --mode production",
    "watch": "npm run watch:extension & npm run watch:webviews",
    "watch:extension": "tsc -watch -p ./",
    "watch:webviews": "webpack --mode development --watch",
    "build": "npm run compile",
    "build:quick": "webpack --mode production --env quick=true",
    "package": "npm run compile && npx --yes @vscode/vsce package",
    "publish:openvsx": "npx --yes ovsx publish"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "@lit/context": "^1.1.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^5.0.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1",
    "esbuild-loader": "^4.1.1",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "css-loader": "^7.1.2",
    "sass": "^1.80.0",
    "sass-loader": "^16.0.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "copy-webpack-plugin": "^12.0.2"
  }
}
